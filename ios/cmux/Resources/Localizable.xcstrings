    "mobile.settings.deleteAccountPartialFailureMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your cmux data was deleted, but account sign-in cleanup did not finish. Try Delete Account again to complete deletion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux のデータは削除されましたが、アカウントのサインイン情報のクリーンアップは完了しませんでした。削除を完了するには、もう一度「アカウントを削除」をお試しください。"
          }
        }
      }
    },
    "mobile.settings.deleteAccountServerCleanupIncompleteMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account sign-in was deleted, but some cmux cleanup did not finish. You will be signed out. Contact support if cmux data is still visible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントのサインイン情報は削除されましたが、一部の cmux クリーンアップは完了しませんでした。サインアウトします。cmux データがまだ表示される場合はサポートにお問い合わせください。"
          }
        }
      }
    },
