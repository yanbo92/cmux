        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux アカウントと cmux のデータを完全に削除します。このデバイスではサインアウトされます。"
          }
        }
      }
    },
    "mobile.settings.deleteAccountTitle": {
