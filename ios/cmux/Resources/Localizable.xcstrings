        }
      }
    },
    "mobile.onboarding.connectBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux uses Iroh by default. It connects directly to your Mac when possible and uses a cmux relay when needed. Your Mac's identity and cmux account are verified end to end, so the relay cannot read terminal traffic."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxはデフォルトでIrohを使用します。可能な場合はMacへ直接接続し、必要な場合のみcmuxリレーを使用します。MacのIDとcmuxアカウントはエンドツーエンドで検証されるため、リレーはターミナル通信を読み取れません。"
          }
        }
      }
    },
    "mobile.onboarding.connectTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypted wherever you connect"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どこからでも暗号化接続"
          }
        }
      }
    },
    "mobile.onboarding.getStarted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get started"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "始める"
          }
        }
      }
    },
    "mobile.onboarding.next": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次へ"
          }
        }
      }
    },
    "mobile.onboarding.pairBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Pair iPhone in cmux on your Mac and scan its Iroh code. cmux saves the verified Mac identity and reconnects automatically. Tailscale, another VPN, or the same LAN may speed up the authenticated Iroh connection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのcmuxで「iPhoneをペアリング」を開き、Irohコードをスキャンします。cmuxは検証済みのMac IDを保存して自動的に再接続します。Tailscale、別のVPN、または同じLANにより、認証済みのIroh接続が高速になる場合があります。"
          }
        }
      }
    },
    "mobile.onboarding.pairTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pair your Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macとペアリング"
          }
        }
      }
    },
    "mobile.onboarding.privateNetworkBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After cmux admits both devices over Iroh, Tailscale, WireGuard, another VPN, or the same LAN may become a faster direct path. They are optional, and Iroh keeps its encryption and identity checks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxがIroh上で両方の端末を認証した後、Tailscale、WireGuard、別のVPN、または同じLANが、より高速な直接経路になる場合があります。これらは任意で、Irohの暗号化とID検証は維持されます。"
          }
        }
      }
    },
    "mobile.onboarding.privateNetworkStep1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign this phone and the Mac in to the same cmux account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneとMacを同じcmuxアカウントでサインインします。"
          }
        }
      }
    },
    "mobile.onboarding.privateNetworkStep2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave cmux running on the Mac so Iroh can reconnect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Irohが再接続できるよう、Macでcmuxを起動したままにします。"
          }
        }
      }
    },
    "mobile.onboarding.privateNetworkStep3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional: connect both devices to the same private network so an admitted Iroh session can migrate to it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意：認証済みのIrohセッションが移行できるよう、両方の端末を同じプライベートネットワークに接続します。"
          }
        }
      }
    },
    "mobile.onboarding.privateNetworkTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Private networks stay available"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プライベートネットワークも利用可能"
          }
        }
      }
    },
    "mobile.onboarding.skip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキップ"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleAppStoreLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional: Tailscale for iPhone"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意：iPhone版Tailscale"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale is a free app that gives your devices a private network. Do this once, on both the phone and the Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscaleは、端末同士をプライベートなネットワークでつなぐ無料アプリです。iPhoneとMacの両方で一度だけ設定してください。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional: Tailscale for Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意：Mac版Tailscale"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install Tailscale on this phone and on your Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末とMacの両方にTailscaleをインストールします。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign both in to the same Tailscale account so they share one tailnet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じTailscaleアカウントでサインインし、同じtailnetを共有させます。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep both signed in to the same cmux account too. Pairing checks that they match."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じcmuxアカウントでもサインインしておきます。ペアリング時に一致を確認します。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Put both devices on Tailscale"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方の端末をTailscaleに入れる"
          }
        }
      }
    },
    "mobile.onboarding.troubleConnecting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouble connecting?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続できないときは"
          }
        }
      }
    },
    "mobile.onboarding.whatBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux runs your terminals and AI coding agents on your Mac. This app lets you watch them, type, and get notified when an agent needs you, right from your phone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxはMac上でターミナルとAIコーディングエージェントを動かします。このアプリを使えば、iPhoneからその様子を見たり、入力したり、エージェントから呼ばれたときに通知を受け取れます。"
          }
        }
      }
    },
    "mobile.onboarding.whatTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac's terminals, on your phone"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのターミナルを、iPhoneで"
          }
        }
      }
    },
    "mobile.pairing.accountMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac is signed in to a different cmux account. Sign out and sign back in with the account that owns this Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このMacは別のcmuxアカウントでサインインしています。サインアウトして、このMacを所有するアカウントでサインインし直してください。"
          }
        }
      }
    },
    "mobile.pairing.appNotRunning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac is reachable, but cmux isn't running there (or mobile pairing is off). Open cmux on the Mac, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macには接続できますが、cmuxが起動していません（またはモバイルのペア設定がオフです）。Macでcmuxを開いてから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.attachTicketExpired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing link expired. Pair again with a fresh QR/link from that computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリングリンクの有効期限が切れました。そのコンピュータの新しい QR/リンクでペアリングしてください。"
          }
        }
      }
    },
    "mobile.pairing.authEnvironmentMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This dev build is signed in to cmux's development auth environment, so its account can never match a Mac running the release app — even with the same email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この開発ビルドは cmux の開発用認証環境にサインインしているため、同じメールアドレスでも、リリース版アプリを実行している Mac のアカウントとは一致しません。"
          }
        }
      }
    },
    "mobile.pairing.authEnvironmentMismatch.devMac": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone uses cmux's production sign-in, but this Mac runs a dev build on the development auth environment, so their accounts can never match — even with the same email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は cmux の本番サインインを使用していますが、この Mac は開発用認証環境の開発ビルドを実行しているため、同じメールアドレスでもアカウントは一致しません。"
          }
        }
      }
    },
    "mobile.pairing.authorizationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't verify your account with this Mac. Make sure both devices are signed in with the same email, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac でアカウントを確認できませんでした。両方のデバイスが同じメールアドレスでサインインしていることを確認してから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.cameraDenied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera Access Required"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラへのアクセスが必要です"
          }
        }
      }
    },
    "mobile.pairing.cameraUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera Unavailable"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラを使用できません"
          }
        }
      }
    },
    "mobile.pairing.codePlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing code"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリングコード"
          }
        }
      }
    },
    "mobile.pairing.compatibilityDisplayFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "compatibility %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "互換性 %@"
          }
        }
      }
    },
    "mobile.pairing.compatibilityUnknown": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "unknown compatibility"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不明な互換性"
          }
        }
      }
    },
    "mobile.pairing.connect": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続"
          }
        }
      }
    },
    "mobile.pairing.connectTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the Mac is awake, cmux is running, and the private route is active."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。Macが起動していてcmuxが実行中であり、プライベート経路が有効か確認してください。"
          }
        }
      }
    },
    "mobile.pairing.connectionDroppedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected to %@:%d, but the host closed the connection. Check that the host app is still running."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に接続しましたが、ホストが接続を閉じました。ホストアプリがまだ実行中であることを確認してください。"
          }
        }
      }
    },
    "mobile.pairing.connectionFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not reach %@:%d. Check that the saved private network or LAN route is active and that the port is correct."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に到達できませんでした。保存済みのプライベートネットワークまたはLAN経路が有効で、ポートが正しいか確認してください。"
          }
        }
      }
    },
    "mobile.pairing.connectionTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the host app is open and accepting mobile connections."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。ホストアプリが開いていて、モバイル接続を受け入れていることを確認してください。"
          }
        }
      }
    },
    "mobile.pairing.dnsFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't resolve %@. Check the DNS or private network that provides this saved route."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ を解決できませんでした。この保存済み経路を提供するDNSまたはプライベートネットワークを確認してください。"
          }
        }
      }
    },
    "mobile.pairing.emailMismatchFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This QR is for %@, but this iPhone is signed in as %@. Sign in with the same email as the Mac, then scan again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この QR は %@ 用ですが、この iPhone は %@ としてサインインしています。Mac と同じメールアドレスでサインインしてから、もう一度スキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.emailMissingFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This QR is for %@. Sign in with the same email as the Mac, then scan again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この QR は %@ 用です。Mac と同じメールアドレスでサインインしてから、もう一度スキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.fail.offline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device looks offline. Connect to Wi-Fi or cellular, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末はオフラインのようです。Wi-Fiまたはモバイルデータに接続してから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.authEnvironment": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rebuild this app with production auth (ios/scripts/reload.sh --prod-auth), or pair with a dev-channel Mac signed in to the same account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本番認証を使ってこのアプリをビルドし直す（ios/scripts/reload.sh --prod-auth）か、同じアカウントでサインインした開発チャネルの Mac とペアリングしてください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.authEnvironment.devMac": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pair with a Mac running the release cmux app, or use a development-channel iPhone build for dev Macs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リリース版の cmux アプリを実行している Mac とペアリングするか、開発用の Mac には開発チャネルの iPhone ビルドを使用してください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.localNetwork": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings > cmux > Local Network, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定 > cmux > ローカルネットワーク を開いてから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.openMacApp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open cmux on your Mac, then scan the QR or link from it again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macでcmuxを開いてから、そのQRコードまたはリンクをもう一度スキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.reachability": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Iroh reconnects automatically. For a saved private-network fallback, connect both devices to that network, wake the Mac, and open cmux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Irohは自動的に再接続します。保存済みのプライベートネットワークをフォールバックに使う場合は、両方の端末をそのネットワークに接続し、Macを起こしてcmuxを開いてください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.rescanFresh": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the pairing window on your Mac and scan a fresh QR or link."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macでペアリングウィンドウを開き、新しいQRコードまたはリンクをスキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.guidance.sameAccount": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both devices must be signed in to the same cmux account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方の端末が同じcmuxアカウントでサインインしている必要があります。"
          }
        }
      }
    },
    "mobile.pairing.guidance.updateApp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update cmux from the App Store (or TestFlight), then scan again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store（またはTestFlight）でcmuxを更新してから、もう一度スキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.hostUnreachableFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can't reach %@:%d. Make sure your Mac is awake and the private network or LAN for this saved route is active."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に接続できません。Macが起動していて、この保存済み経路のプライベートネットワークまたはLANが有効か確認してください。"
          }
        }
      }
    },
    "mobile.pairing.invalidCode": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This isn't a cmux pairing QR. Scan the code shown in the Pair iPhone window on your Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはcmuxのペアリングQRコードではありません。Macの「iPhoneをペアリング」ウインドウに表示されているコードをスキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.localNetworkPermission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS blocked the connection. Allow cmux to use the Local Network in iOS Settings, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSが接続をブロックしました。iOSの設定でcmuxにローカルネットワークの使用を許可してから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.loopbackRejected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This code points at the Mac itself (localhost), so your iPhone can't use it. Update cmux on the Mac and scan its Iroh code."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このコードはMac自身（localhost）を指しているため、iPhoneからは使えません。Macのcmuxを更新し、Irohコードをスキャンしてください。"
          }
        }
      }
    },
    "mobile.pairing.navigationTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング"
          }
        }
      }
    },
    "mobile.pairing.requestTimedOut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The computer did not respond. Check the host and port, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータが応答しませんでした。ホストとポートを確認して、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.runtimeUnavailable": {
      "extractionState": "manual",
