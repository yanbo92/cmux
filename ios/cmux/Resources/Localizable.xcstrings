        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントの削除が完了したか確認できませんでした。少し待ってから、もう一度「アカウントを削除」をお試しください。"
          }
        }
      }
    },
    "mobile.settings.deleteAccountMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently deletes your cmux account and cmux data. You will be signed out on this device."
